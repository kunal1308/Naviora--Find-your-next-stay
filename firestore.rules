rules_version = '2';

// Naviora Firestore security rules.
// Paste into: Firebase console → Firestore Database → Rules → Publish.
// (Later we can deploy these with the Firebase CLI so they live in git.)

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin check by email. (A production app would use custom claims.)
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'karan.arora040820@gmail.com';
    }

    // Hotels — public read. Admin can write anything; a signed-in user can
    // create a listing they own and manage only their own listings.
    match /hotels/{doc} {
      allow read: if true;
      allow create: if isAdmin()
        || (request.auth != null
            && request.resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (request.auth != null
            && resource.data.ownerId == request.auth.uid);
    }

    match /destinations/{doc} { allow read: if true; allow write: if isAdmin(); }
    match /reviews/{doc}      { allow read: if true; allow write: if isAdmin(); }

    // A user owns their profile doc (holds wishlist + avatarUrl).
    // The admin may read all user docs (for the admin Users page).
    match /users/{uid} {
      allow read: if request.auth != null
        && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Bookings: a signed-in user can create, read, and update only their own.
    // (Edit/cancel go through update; the "1 day before" rule is enforced in
    //  the app. Ownership can't be reassigned on update.)
    match /bookings/{id} {
      allow read:   if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.userId == resource.data.userId;
      allow delete: if false;
    }

    // Everything else denied by default.
    match /{document=**} { allow read, write: if false; }
  }
}
